# Project-local cache: copy .npm-offline-cache with the repo for air-gapped installs.
# Online (connected):  npm install  OR  npm run vendor:npm-cache
# Offline (defence):   npm run install:offline  OR  deploy\install-offline.bat
# Do NOT add offline=true here during development — install-offline.js sets it via env.
cache=.npm-offline-cache
prefer-offline=true
