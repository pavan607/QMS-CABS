# --- Required ---
# External PostgreSQL (SSL params optional, e.g. ?sslmode=require)
#
# DATABASE_URL — Postgres connection string.
# With docker-compose as shipped, DOCKER_PG_HOST=host.docker.internal rewrites localhost/127.0.0.1
# so you can reuse the same URL as `npm start` (e.g. ...@localhost:5432/...).
# For a remote DB, use the real hostname (no rewrite applies).
DATABASE_URL=postgresql://qms_user:CHANGE_ME@localhost:5432/qms_db

# NextAuth v5 — generate: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Public URL users use to open the app (scheme matters for cookies)
# Use https:// in production; for plain HTTP behind LAN set AUTH_COOKIE_SECURE=false
AUTH_URL=http://your-server:3000

# Required for Auth.js v5 in production (Docker, reverse proxy, or non-default host)
AUTH_TRUST_HOST=true

# --- Uploads on the host (bind mount target) ---
# Absolute path on the Docker host; must be writable by container user uid 1001
UPLOADS_HOST_PATH=/var/lib/qms/uploads

# --- Optional ---
HTTP_PORT=3000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Plain HTTP only (no TLS): avoid if possible — use HTTPS above.
# AUTH_COOKIE_SECURE=false

# Legacy alias (still read by auth if AUTH_URL unset):
# NEXTAUTH_URL=http://your-server:3000
# NEXTAUTH_SECRET=same-as-AUTH_SECRET
