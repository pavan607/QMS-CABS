# Database Configuration
# Format: postgresql://username:password@host:port/database
# Local dev (no Docker): localhost is fine.
# Docker: use host.docker.internal instead of localhost so the container reaches Postgres on the host.
DATABASE_URL=postgresql://postgres:root@localhost:5432/QMS

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Email Configuration (Optional - for notifications)
# EMAIL_FROM=noreply@yourcompany.com
# SENDGRID_API_KEY=your-sendgrid-api-key

# Cron Job Security (Optional - for automated alerts)
# CRON_SECRET=your-cron-secret-here

